# ─────────────────────────────────────────────
#  SERVER
# ─────────────────────────────────────────────

# Port the Express server listens on
PORT=5001

# ─────────────────────────────────────────────
#  DATABASE
# ─────────────────────────────────────────────

# MongoDB connection string
# Local:   mongodb://127.0.0.1:27017/alfanex
# Atlas:   mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/alfanex?retryWrites=true&w=majority
# Pooler (transaction mode - for app connections)
DATABASE_URL=postgresql://postgres.lgwnmwntoewwgkddrshd:eF3%26ML6mAPu%26sLf@aws-1-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=13

# Direct connection (for prisma db push / migrations)
DIRECT_URL=postgresql://postgres.lgwnmwntoewwgkddrshd:eF3%26ML6mAPu%26sLf@aws-1-ap-south-1.pooler.supabase.com:5432/postgres

# ─────────────────────────────────────────────
#  AUTH / JWT
# ─────────────────────────────────────────────

# Secret used to sign short-lived access tokens (8 h)
# Use any long random string — e.g. openssl rand -hex 32
JWT_SECRET=alfanex_jwt_s3cr3t_k3y_2024_xZ9q

# Secret used to sign long-lived refresh tokens (7 d)
# Must be different from JWT_SECRET
JWT_REFRESH_SECRET=alfanex_refresh_s3cr3t_k3y_2024_mN7p

# ─────────────────────────────────────────────
#  FRONTEND
# ─────────────────────────────────────────────

# Origin of the React dev server (for CORS)
# Change to your production domain when deploying
CLIENT_URL=http://localhost:5173

# ─────────────────────────────────────────────
#  GOOGLE SHEETS BACKUP  (optional)
#  Leave all three blank to skip sheet sync
# ─────────────────────────────────────────────

# Service account email from Google Cloud Console
# e.g. myapp@my-project-123456.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_EMAIL=

# Private key from the service account JSON key file
# Copy the entire "private_key" value including -----BEGIN / END----- lines
# Replace literal newlines with \n  (the app converts them back)
GOOGLE_PRIVATE_KEY=

# ID of the Google Sheet to write into
# Found in the sheet URL: docs.google.com/spreadsheets/d/<SHEET_ID>/edit
GOOGLE_SHEET_ID=
